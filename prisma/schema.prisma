generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(uuid())
  name      String?
  email     String   @unique
  password  String
  role      String   @default("VIEWER") // ADMIN, OFFICER, VIEWER
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Suspect {
  id          String   @id @default(uuid())
  fullName    String
  aliases     String?
  dateOfBirth DateTime?
  idNumber    String?  @unique
  address     String?
  bloodType   String?
  height      Float?
  weight      Float?
  features    String?  // Scars, tattoos, etc.
  status      String   @default("UNKNOWN") // WANTED, IN_PRISON, RELEASED, UNKNOWN
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cases       CaseSuspect[]
}

model Case {
  id          String   @id @default(uuid())
  caseNumber  String   @unique
  title       String
  description String?
  date        DateTime?
  location    String?
  status      String   @default("OPEN") // OPEN, CLOSED, COLD
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  suspects    CaseSuspect[]
}

model CaseSuspect {
  id         String   @id @default(uuid())
  caseId     String
  suspectId  String
  role       String?  // MAIN_SUSPECT, ACCOMPLICE, WITNESS
  createdAt  DateTime @default(now())

  case       Case     @relation(fields: [caseId], references: [id])
  suspect    Suspect  @relation(fields: [suspectId], references: [id])

  @@unique([caseId, suspectId])
}
